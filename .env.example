# Copy this file to .env and fill in your actual values
# NOTE: .env file is only used for local testing

# Forgejo API Configuration
FORGEJO_URL=https://git.yourdomain.com
FORGEJO_ORGANIZATION=thstr
FORGEJO_REPOSITORY=your-repo-name
RELEASE_TAG=v1.0.0
INPUT_FORGEJO_TOKEN=your-actual-token-here

# GitHub Actions output file for testing
GITHUB_OUTPUT=./test-output.txt